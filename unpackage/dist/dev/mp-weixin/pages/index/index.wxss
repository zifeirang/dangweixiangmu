
/* 容器设为相对定位，方便子元素绝对定位 */
.container.data-v-1cf27b2a {
  width: 100vw;
  height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  /* 防止内容溢出 */
  overflow: hidden;
}

/* 背景图：绝对定位覆盖全屏，层级调低 */
.bg-img.data-v-1cf27b2a {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 40%;
  z-index: -1; /* 让按钮在背景图上层 */
  /* 适配不同屏幕，保持比例 */
  object-fit: cover;
}

/* 按钮组样式 */
.btn-group.data-v-1cf27b2a {
  width: 80%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  /* 原200px改为400rpx，适配移动端rpx单位 */
  margin-top: 400rpx;
}

/* 按钮样式 */
.btn.data-v-1cf27b2a {
  height: 100rpx;
  line-height: 100rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50rpx;
  text-align: center;
  font-size: 36rpx;
  color: #000;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  /* 去除navigator默认下划线 */
  text-decoration: none;
  /* 新增：按钮hover/点击动效，提升体验 */
  transition: all 0.2s ease;
}

/* 按钮点击/hover效果 */
.btn.data-v-1cf27b2a:active {
  background-color: rgba(255, 255, 255, 1);
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}
