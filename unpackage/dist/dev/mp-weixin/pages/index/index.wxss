
/* 样式保持不变，和之前的高级简约版一样 */
.container.data-v-1cf27b2a {
  width: 100vw;
  height: 100vh;
  background-color: #F7F8FA;
  display: flex;
  justify-content: center;
}
.safe-area.data-v-1cf27b2a {
  width: 100%;
  max-width: 600px;
  padding: 120rpx 60rpx 80rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.header-section.data-v-1cf27b2a {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-top: 80rpx;
}
.logo-dot.data-v-1cf27b2a {
  width: 12rpx;
  height: 12rpx;
  background-color: #007AFF;
  border-radius: 50%;
  margin-bottom: 40rpx;
}
.app-name.data-v-1cf27b2a {
  font-size: 56rpx;
  font-weight: 300;
  color: #1D1D1F;
  letter-spacing: -1rpx;
  margin-bottom: 8rpx;
}
.app-slogan.data-v-1cf27b2a {
  font-size: 28rpx;
  font-weight: 400;
  color: #86868B;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}
.menu-section.data-v-1cf27b2a {
  width: 100%;
  margin-top: 120rpx;
}
.menu-item.data-v-1cf27b2a {
  width: 100%;
  height: 140rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 0 36rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s ease;
}
.menu-item.data-v-1cf27b2a:active {
  transform: scale(0.995);
  background-color: #FBFBFB;
}
.menu-left.data-v-1cf27b2a {
  display: flex;
  align-items: center;
}
.menu-icon-box.data-v-1cf27b2a {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
}
.device-color.data-v-1cf27b2a { background-color: #E3F2FD; color: #1976D2;
}
.gateway-color.data-v-1cf27b2a { background-color: #E8F5E9; color: #388E3C;
}
.menu-title.data-v-1cf27b2a {
  font-size: 32rpx;
  font-weight: 500;
  color: #1D1D1F;
  margin-bottom: 6rpx;
  display: block;
}
.menu-sub.data-v-1cf27b2a {
  font-size: 24rpx;
  font-weight: 400;
  color: #86868B;
  display: block;
}
.arrow-icon.data-v-1cf27b2a {
  font-size: 40rpx;
  color: #C7C7CC;
  font-weight: 300;
}
.footer-section.data-v-1cf27b2a {
  display: flex;
  justify-content: center;
  padding-bottom: 20rpx;
}
.version-text.data-v-1cf27b2a {
  font-size: 22rpx;
  color: #C7C7CC;
  letter-spacing: 1rpx;
}
