
/* ---------------- 全局容器 ---------------- */
.container.data-v-45953eac {
  width: 100vw;
  min-height: 100vh;
  background-color: #F7F8FA;
  display: flex;
  justify-content: center;
}
.safe-area.data-v-45953eac {
  width: 100%;
  max-width: 600px;
  padding: 0 40rpx 40rpx;
  box-sizing: border-box;
}

/* ---------------- 核心：固定顶部区域 ---------------- */
.fixed-header.data-v-45953eac {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background-color: #F7F8FA;
  padding: 60rpx 40rpx 20rpx;
  padding-top: calc(60rpx + env(safe-area-inset-top));
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* ---------------- 顶部标题 ---------------- */
.header-section.data-v-45953eac {
  margin-bottom: 20rpx;
}
.page-title.data-v-45953eac {
  display: block;
  font-size: 48rpx;
  font-weight: 300;
  color: #1D1D1F;
  letter-spacing: -1rpx;
  margin-bottom: 8rpx;
}
.page-subtitle.data-v-45953eac {
  display: block;
  font-size: 24rpx;
  font-weight: 400;
  color: #86868B;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* ---------------- 搜索卡片 ---------------- */
.search-card.data-v-45953eac {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}
.search-row.data-v-45953eac {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 选择器 */
.search-picker.data-v-45953eac {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #F7F8FA;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 72rpx;
  flex-shrink: 0;
}
.picker-text.data-v-45953eac {
  font-size: 26rpx;
  color: #1D1D1F;
  margin-right: 8rpx;
}
.picker-arrow.data-v-45953eac {
  font-size: 28rpx;
  color: #C7C7CC;
  font-weight: 300;
}

/* 输入框 */
.search-input.data-v-45953eac {
  flex: 1;
  height: 72rpx;
  background-color: #F7F8FA;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1D1D1F;
}
.input-placeholder.data-v-45953eac {
  color: #C7C7CC;
}

/* 按钮 */
.search-btn.data-v-45953eac, .add-btn.data-v-45953eac {
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.search-btn.data-v-45953eac {
  background-color: #F0F7FF;
}
.search-btn-text.data-v-45953eac {
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 500;
}
.add-btn.data-v-45953eac {
  background-color: #007AFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.25);
}
.add-btn-text.data-v-45953eac {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ---------------- 列表区域（核心：增加顶部内边距） ---------------- */
.list-wrapper.data-v-45953eac {
  width: 100%;
  padding-top: 340rpx;
}

/* 网关大卡片 */
.gateway-card.data-v-45953eac {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  transition: all 0.2s ease;
}
.gateway-card.data-v-45953eac:active {
  transform: scale(0.995);
  background-color: #FBFBFB;
}

/* 左侧信息 */
.card-left.data-v-45953eac {
  flex: 1;
  margin-right: 20rpx;
}
.info-row.data-v-45953eac {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.info-row.data-v-45953eac:last-child {
  margin-bottom: 0;
}
.info-label.data-v-45953eac {
  width: 140rpx;
  font-size: 26rpx;
  color: #86868B;
  flex-shrink: 0;
}
.info-value.data-v-45953eac {
  flex: 1;
  font-size: 28rpx;
  color: #1D1D1F;
  font-weight: 400;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 等宽字体（用于MAC/Key） */
/* .mono {
  font-family: monospace;
  font-size: 26rpx;
} */

/* 右侧状态与操作 */
.card-right.data-v-45953eac {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  height: 160rpx;
}

/* 状态标签 */
.status-tag.data-v-45953eac {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.status-online.data-v-45953eac {
  background-color: #E8F5E9;
  color: #388E3C;
}
.status-offline.data-v-45953eac {
  background-color: #F5F5F7;
  color: #86868B;
}
.status-repair.data-v-45953eac {
  background-color: #FFF3E0;
  color: #F57C00;
}

/* 操作按钮 */
.action-btns.data-v-45953eac {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 20rpx;
}
.action-btn.data-v-45953eac {
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
}
.config-action.data-v-45953eac {
  background-color: #F0F7FF;
}
.detail-action.data-v-45953eac {
  background-color: #F5F5F7;
}
.action-text.data-v-45953eac {
  font-size: 24rpx;
  color: #1D1D1F;
}
.config-action .action-text.data-v-45953eac {
  color: #007AFF;
}

/* 加载/空状态 */
.empty.data-v-45953eac, .loading.data-v-45953eac, .load-more.data-v-45953eac, .no-more.data-v-45953eac {
  padding: 60rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #86868B;
}
