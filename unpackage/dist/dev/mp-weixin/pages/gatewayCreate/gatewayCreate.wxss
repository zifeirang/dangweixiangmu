
/* 全局容器 */
.container.data-v-36c94b3b {
  padding: 20rpx;
  background-color: #f9f9f9;
  min-height: 100vh;
}

/* 表单项通用样式 */
.form-item.data-v-36c94b3b {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

/* 标签样式 */
.label.data-v-36c94b3b {
  width: 150rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0; /* 防止标签被压缩 */
}

/* 输入框+扫码按钮容器 */
.input-group.data-v-36c94b3b {
  flex: 1;
  display: flex;
  align-items: center;
}

/* 输入框通用样式 */
.input.data-v-36c94b3b {
  flex: 1;
  font-size: 28rpx;
  padding: 12rpx 15rpx;
  border: 1rpx solid #eee;
  border-right: none;
  border-radius: 6rpx 0 0 6rpx; /* 左圆角 */
  height: 56rpx;
  box-sizing: border-box;
}

/* 扫码按钮样式（图片版） */
.scan-btn.data-v-36c94b3b {
  width: 70rpx;
  height: 56rpx; /* 与输入框高度完全对齐 */
  background: #ffffff;
  border: none;
  border-radius: 0 6rpx 6rpx 0; /* 右圆角 */
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

/* 扫码图片样式 */
.scan-img.data-v-36c94b3b {
  width: 32rpx; /* 图片宽度 */
  height: 32rpx; /* 图片高度，保持正方形 */
  vertical-align: middle;
}

/* 保存按钮样式 */
.save-btn.data-v-36c94b3b {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #007aff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 32rpx;
  margin-top: 30rpx;
  border: none;
}

/* 禁用/加载状态样式 */
.save-btn.data-v-36c94b3b:disabled {
  background: #999;
  color: #fff;
}
