
/* 全局容器 */
.container.data-v-15045a0f {
  width: 100vw;
  min-height: 100vh;
  background-color: #F7F8FA;
  display: flex;
  justify-content: center;
}
.safe-area.data-v-15045a0f {
  width: 100%;
  max-width: 600px;
  padding: 0 40rpx 120rpx;
  box-sizing: border-box;
}

/* 核心：固定顶部区域 */
.fixed-header.data-v-15045a0f {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background-color: #F7F8FA;
  padding: 60rpx 40rpx 20rpx;
  padding-top: calc(60rpx + env(safe-area-inset-top));
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* 标题（适配固定布局） */
.header-section.data-v-15045a0f {
  margin-bottom: 20rpx;
}
.page-title.data-v-15045a0f {
  display: block;
  font-size: 48rpx;
  font-weight: 300;
  color: #1D1D1F;
  margin-bottom: 6rpx;
}
.page-subtitle.data-v-15045a0f {
  display: block;
  font-size: 24rpx;
  color: #86868B;
  letter-spacing: 2rpx;
}

/* 搜索卡片 */
.search-card.data-v-15045a0f {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
}
.search-row.data-v-15045a0f {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.search-picker.data-v-15045a0f {
  display: flex;
  align-items: center;
  background: #F7F8FA;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
}
.picker-text.data-v-15045a0f {
  font-size: 26rpx;
  color: #1D1D1F;
}
.picker-arrow.data-v-15045a0f {
  font-size: 28rpx;
  color: #C7C7CC;
  font-weight: 300;
  margin-left: 8rpx;
}
.search-input.data-v-15045a0f {
  flex: 1;
  height: 72rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1D1D1F;
}
.input-placeholder.data-v-15045a0f {
  color: #C7C7CC;
}
.search-btn.data-v-15045a0f {
  height: 72rpx;
  padding: 0 24rpx;
  background: #F0F7FF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
}
.search-btn-text.data-v-15045a0f {
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 500;
}

/* 全选栏 */
.select-bar.data-v-15045a0f {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 10rpx;
}
.select-left.data-v-15045a0f {
  display: flex;
  align-items: center;
}
.select-text.data-v-15045a0f {
  font-size: 28rpx;
  color: #1D1D1F;
  margin-left: 12rpx;
}
.count-text.data-v-15045a0f {
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 500;
}

/* 列表区域（核心修改：加大顶部内边距，完全避开固定头部） */
.list-wrapper.data-v-15045a0f {
  width: 100%;
  padding-top: 380rpx;
}

/* 设备卡片 */
.device-card.data-v-15045a0f {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
  overflow: hidden;
  transition: all 0.2s ease;
}
.device-card.data-v-15045a0f:active {
  transform: scale(0.995);
  background-color: #FBFBFB;
}
.card-main.data-v-15045a0f {
  display: flex;
  align-items: flex-start;
}
.card-checkbox.data-v-15045a0f {
  margin-right: 20rpx;
  transform: scale(1.1);
  flex-shrink: 0;
  margin-top: 4rpx;
}
.card-info.data-v-15045a0f {
  flex: 1;
  margin-right: 20rpx;
}
.info-row.data-v-15045a0f {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.info-row.data-v-15045a0f:last-child {
  margin-bottom: 0;
}
.info-label.data-v-15045a0f {
  width: 140rpx;
  font-size: 26rpx;
  color: #86868B;
  flex-shrink: 0;
}
.info-value.data-v-15045a0f {
  flex: 1;
  font-size: 28rpx;
  color: #1D1D1F;
  font-weight: 400;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.mono.data-v-15045a0f {
  font-family: monospace;
  font-size: 26rpx;
}

/* 状态标签 */
.status-tag.data-v-15045a0f {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.status-online.data-v-15045a0f { background-color: #E8F5E9; color: #388E3C;
}
.status-offline.data-v-15045a0f { background-color: #F5F5F7; color: #86868B;
}
.status-repair.data-v-15045a0f { background-color: #FFF3E0; color: #F57C00;
}
/* 新增：计量状态标签样式 */
.status-normal.data-v-15045a0f { background-color: #E8F5E9; color: #388E3C;
}
.status-alarm.data-v-15045a0f { background-color: #FFEAEA; color: #FF3B30;
}

/* 状态和操作按钮容器 */
.status-with-action.data-v-15045a0f {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 解除告警按钮 */
.clear-alarm-btn.data-v-15045a0f {
  padding: 6rpx 16rpx;
  background-color: #F0F7FF;
  border-radius: 20rpx;
}
.clear-alarm-text.data-v-15045a0f {
  font-size: 22rpx;
  font-weight: 500;
  color: #007AFF;
}

/* 展开箭头 */
.expand-icon.data-v-15045a0f {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  margin-top: 4rpx;
}
.arrow.data-v-15045a0f {
  font-size: 28rpx;
  color: #C7C7CC;
  transition: transform 0.2s;
}
.expand-icon.active .arrow.data-v-15045a0f {
  transform: rotate(180deg);
}

/* 展开操作区 */
.card-actions.data-v-15045a0f {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F5F5F7;
}
.action-grid.data-v-15045a0f {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.action-item.data-v-15045a0f {
  flex: 1;
  min-width: 140rpx;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.action-text.data-v-15045a0f {
  font-size: 26rpx;
  font-weight: 500;
}

/* 操作按钮配色 */
.light-on.data-v-15045a0f { background-color: #E8F5E9;
}
.light-on .action-text.data-v-15045a0f { color: #388E3C;
}
.light-off.data-v-15045a0f { background-color: #F5F5F7;
}
.light-off .action-text.data-v-15045a0f { color: #86868B;
}
.socket-on.data-v-15045a0f { background-color: #F0F7FF;
}
.socket-on .action-text.data-v-15045a0f { color: #007AFF;
}
.socket-off.data-v-15045a0f { background-color: #FFEAEA;
}
.socket-off .action-text.data-v-15045a0f { color: #FF3B30;
}
.screen.data-v-15045a0f { background-color: #F3E5F5;
}
.screen .action-text.data-v-15045a0f { color: #9C27B0;
}
.kick.data-v-15045a0f { background-color: #FFF3E0;
}
.kick .action-text.data-v-15045a0f { color: #FF6700;
}
/* 三个查询按钮配色 */
.mcu-version.data-v-15045a0f { background-color: #E3F2FD;
}
.mcu-version .action-text.data-v-15045a0f { color: #1976D2;
}
.light-status.data-v-15045a0f { background-color: #FFF8E1;
}
.light-status .action-text.data-v-15045a0f { color: #FF8F00;
}
.socket-status.data-v-15045a0f { background-color: #E8F5E9;
}
.socket-status .action-text.data-v-15045a0f { color: #2E7D32;
}
/* 计量状态按钮配色 */
.measurement-status.data-v-15045a0f { background-color: #F3E5F5;
}
.measurement-status .action-text.data-v-15045a0f { color: #7B1FA2;
}

/* 电参数显示行 */
.device-metrics-row.data-v-15045a0f {
  display: flex;
  flex-wrap: wrap;
  padding-top: 16rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid #F5F5F7;
}
.metrics-item.data-v-15045a0f {
  width: 50%;
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}
.metrics-label.data-v-15045a0f {
  font-size: 24rpx;
  color: #86868B;
  margin-right: 8rpx;
}
.metrics-value.data-v-15045a0f {
  font-size: 24rpx;
  color: #1D1D1F;
  font-weight: 500;
}

/* 加载/空状态 */
.loading.data-v-15045a0f, .empty.data-v-15045a0f, .load-more.data-v-15045a0f, .no-more.data-v-15045a0f {
  text-align: center;
  padding: 60rpx 0;
  font-size: 26rpx;
  color: #86868B;
}

/* 批量按钮 */
.batch-btn.data-v-15045a0f {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: #007AFF;
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(0,122,255,0.25);
  z-index: 999;
}
