
/* 完全对齐设置页样式 */
.container.data-v-7a762f89 {
  width: 100vw;
  min-height: 100vh;
  background-color: #F7F8FA;
  display: flex;
  justify-content: center;
}
.safe-area.data-v-7a762f89 {
  width: 100%;
  max-width: 600px;
  padding: 80rpx 40rpx 140rpx;
  box-sizing: border-box;
}

/* 标题 */
.header-section.data-v-7a762f89 {
  margin-bottom: 40rpx;
}
.page-title.data-v-7a762f89 {
  display: block;
  font-size: 48rpx;
  font-weight: 300;
  color: #1D1D1F;
  letter-spacing: -1rpx;
  margin-bottom: 8rpx;
}
.page-subtitle.data-v-7a762f89 {
  display: block;
  font-size: 24rpx;
  font-weight: 400;
  color: #86868B;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* 卡片 */
.form-group.data-v-7a762f89 {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  overflow: hidden;
}
.group-header.data-v-7a762f89 {
  width: 100%;
  padding: 30rpx 36rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid #F5F5F7;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.group-title.data-v-7a762f89 {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D1D1F;
}

/* 网关信息行 */
.info-item.data-v-7a762f89 {
  display: flex;
  align-items: center;
  padding: 24rpx 36rpx;
  border-bottom: 1rpx solid #F5F5F7;
}
.info-item.data-v-7a762f89:last-child {
  border-bottom: none;
}
.label.data-v-7a762f89 {
  width: 160rpx;
  font-size: 26rpx;
  color: #86868B;
  flex-shrink: 0;
}
.value.data-v-7a762f89 {
  flex: 1;
  font-size: 28rpx;
  color: #1D1D1F;
}
.copy-btn.data-v-7a762f89 {
  padding: 8rpx 16rpx;
  background: #F0F7FF;
  color: #007AFF;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: none;
}

/* 操作按钮区域 */
.operate-row.data-v-7a762f89 {
  padding: 20rpx 36rpx;
  border-bottom: 1rpx solid #F5F5F7;
}
.operate-btn-group.data-v-7a762f89 {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
.operate-btn.data-v-7a762f89 {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  border: none;
  font-weight: 500;
}
.light-on.data-v-7a762f89 { background-color: #E8F5E9; color: #388E3C;
}
.light-off.data-v-7a762f89 { background-color: #F5F5F7; color: #86868B;
}
.socket-on.data-v-7a762f89 { background-color: #F0F7FF; color: #007AFF;
}
.socket-off.data-v-7a762f89 { background-color: #FFEAEA; color: #FF3B30;
}
.screen-btn.data-v-7a762f89 { background-color: #F3E5F5; color: #9C27B0;
}
/* 初始化按钮配色 */
.init-btn.data-v-7a762f89 { background-color: #EDE7F6; color: #673AB7;
}
.kick-out-btn.data-v-7a762f89 { background-color: #FFF3E0; color: #FF6700;
}

/* 添加按钮 */
.mini-add-btn.data-v-7a762f89 {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  background: #E3F2FD;
  color: #1976D2;
  border-radius: 12rpx;
  font-size: 24rpx;
  border: none;
}

/* 表格 */
.device-table.data-v-7a762f89 {
  width: 100%;
}
.table-header.data-v-7a762f89 {
  display: flex;
  background: #F7F8FA;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F7;
}
.table-row.data-v-7a762f89 {
  display: flex;
  min-height: 80rpx;
  border-bottom: 1rpx solid #F5F5F7;
  align-items: center;
}
.table-row.data-v-7a762f89:last-child {
  border-bottom: none;
}
.selected-row.data-v-7a762f89 {
  background-color: #F0F7FF;
}
.table-col.data-v-7a762f89 {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #1D1D1F;
  padding: 20rpx 10rpx;
}
.col-select.data-v-7a762f89 { width: 80rpx; flex-shrink: 0;
}
.col-index.data-v-7a762f89 { width: 80rpx; flex-shrink: 0;
}
.col-mac.data-v-7a762f89 { flex: 2;
}
.col-seat.data-v-7a762f89 { flex: 1;
}
.device-checkbox.data-v-7a762f89 {
  transform: scale(1);
}
.empty.data-v-7a762f89, .loading.data-v-7a762f89 {
  padding: 60rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #86868B;
}

/* 电参数显示行 */
.device-metrics-row.data-v-7a762f89 {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 36rpx;
  background-color: #F9F9F9;
  border-bottom: 1rpx solid #F5F5F7;
}
.metrics-item.data-v-7a762f89 {
  width: 50%;
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}
.metrics-label.data-v-7a762f89 {
  font-size: 24rpx;
  color: #86868B;
  margin-right: 8rpx;
}
.metrics-value.data-v-7a762f89 {
  font-size: 24rpx;
  color: #1D1D1F;
  font-weight: 500;
}

/* 底部批量按钮 */
.batch-btn.data-v-7a762f89 {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: #007AFF;
  color: #fff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(0,122,255,0.25);
  z-index: 999;
  max-width: 520rpx;
  margin: 0 auto;
}
