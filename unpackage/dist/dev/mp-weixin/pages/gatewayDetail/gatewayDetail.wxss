/* ========== 表格样式 ========== */
.device-table.data-v-7a762f89 {
  width: calc(100% - 40rpx);
  border: 1rpx solid #e5e9f2;
  border-radius: 12rpx;
  overflow: hidden;
  margin: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.table-header.data-v-7a762f89 {
  display: flex;
  background: #f5f7fa;
  font-weight: 600;
  color: #333;
}
.table-row.data-v-7a762f89 {
  display: flex;
  border-bottom: 1rpx solid #e5e9f2;
  min-height: 80rpx;
  transition: background-color 0.2s;
}

/* 交替行背景色 */
.table-row.data-v-7a762f89:nth-child(even) {
  background-color: #fcfdff;
}

/* 选中行高亮 */
.selected-row.data-v-7a762f89 {
  background-color: #e6f7ff;
}

/* ========== 列宽对齐 ========== */
.table-col.data-v-7a762f89 {
  padding: 20rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 26rpx;
}
.col-select.data-v-7a762f89 {
  width: 80rpx;
  flex: none;
}
.col-index.data-v-7a762f89 {
  width: 60rpx;
  flex: none;
}
.col-mac.data-v-7a762f89 {
  flex: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.col-seat.data-v-7a762f89 {
  flex: 1;
}

/* 复选框样式统一 */
.device-checkbox.data-v-7a762f89 {
  transform: scale(0.9);
}
/* 全选框样式（和普通复选框一致） */
.all-select-checkbox.data-v-7a762f89 {
  transform: scale(0.9);
}
.empty.data-v-7a762f89, .loading.data-v-7a762f89 {
  padding: 40rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}
